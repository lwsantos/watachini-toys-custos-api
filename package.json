{
  "name": "3d-printing-cost-control-backend",
  "version": "1.0.0",
  "description": "Backend para sistema de controle de custos de impressão 3D",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/infrastructure/database/typeorm/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/infrastructure/database/typeorm/data-source.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/infrastructure/database/typeorm/data-source.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docker:stop": "docker stop custos-backend || true && docker rm custos-backend || true",
    "docker:build": "docker build -t custos-backend .",
    "docker:run": "docker run -d --name custos-backend --restart unless-stopped --env-file .env --add-host=host.docker.internal:host-gateway -p 4000:4000 custos-backend",
    "deploy": "npm run docker:stop && npm run docker:build && npm run docker:run"
  },
  "keywords": [
    "3d-printing",
    "cost-control",
    "typescript",
    "express",
    "typeorm"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@types/uuid": "^10.0.0",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
